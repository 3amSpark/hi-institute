---
import FadeIn from "../components/fade-in";
import Navbar from "../components/navbar";
import Root from "../layouts/root.astro";

const whatsappUrl =
  "https://wa.me/50252810472?text=%C2%A1Hola!%20Estoy%20interesada(o)%20en%20agendar%20una%20evaluaci%C3%B3n%20metab%C3%B3lica%20y%20hormonal";

const socialLinks = [
  {
    href: "https://www.instagram.com/healthinstitute_int/",
    label: "Instagram",
    icon: "instagram",
  },
  {
    href: "https://www.facebook.com/HealthInstituteInt/",
    label: "Facebook",
    icon: "facebook",
  },
];
---

<Root
  title="Contacto | HI Institute"
  description="Escríbenos y agenda tu evaluación metabólica y hormonal en HI Institute."
>
  <Navbar client:load currentPath={Astro.url.pathname} />
  <main>
    <section
      class="relative mt-14 flex min-h-[calc(100svh-3.5rem)] items-center overflow-hidden bg-[#287cc2] px-6 py-24 text-center text-white md:mt-[4.125rem] md:min-h-[calc(100svh-4.125rem)] lg:px-10"
    >
      <div
        class="absolute inset-0 bg-linear-to-r from-[#65b9bd] via-[#207bc3] to-[#cdd1d2]"
        aria-hidden="true"
      >
      </div>
      <div
        class="bg-brand-green/85 absolute -bottom-1/3 -left-1/5 h-3/4 w-1/2 rounded-full blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="bg-brand-blue/70 absolute top-0 left-1/4 h-3/4 w-1/2 rounded-full blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div
        class="absolute top-0 right-0 h-full w-1/2 bg-linear-to-l from-white/35 to-transparent"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 mx-auto flex max-w-4xl flex-col items-center">
        <FadeIn
          client:visible
          as="h1"
          className="max-w-3xl text-(length:--step-3)/10 font-medium tracking-tight text-white text-shadow-md/10"
        >
          ¿No te sientes bien y no sabes<br class="hidden md:block" />
          por dónde empezar?
        </FadeIn>

        <div class="mt-10 space-y-6 text-(length:--step-0)/8">
          <p>
            No tienes que resolverlo solo.<br />
            Estamos aquí para escucharte y entender tu cuerpo.
          </p>
          <p>
            Escríbenos y agenda tu evaluación metabólica y hormonal.<br />
            Te acompañamos paso a paso para encontrar<br
              class="hidden md:block"
            />
            el tratamiento adecuado para ti.
          </p>
        </div>

        <a
          href={whatsappUrl}
          target="_blank"
          rel="noreferrer"
          class="to-brand-green mt-24 inline-flex min-w-72 justify-center rounded-full bg-linear-to-r from-[#31ADD0] px-10 py-2 text-(length:--step-0) font-medium text-white transition-opacity hover:opacity-90 md:min-w-80"
        >
          EMPIEZA AQUÍ
        </a>

        <div class="mt-4 flex items-center justify-center gap-5 text-white/85">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                aria-label={link.label}
                target="_blank"
                rel="noreferrer"
                class="transition-opacity hover:opacity-75"
              >
                {link.icon === "instagram" ? (
                  <svg
                    class="size-11 md:size-12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect x="3" y="3" width="18" height="18" rx="5" />
                    <circle cx="12" cy="12" r="4" />
                    <circle
                      cx="17.5"
                      cy="6.5"
                      r="1"
                      fill="currentColor"
                      stroke="none"
                    />
                  </svg>
                ) : null}
                {link.icon === "facebook" ? (
                  <svg
                    class="size-11 md:size-12"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2V8.6H15.2c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.91h-2.34V22C18.34 21.24 22 17.08 22 12.06Z" />
                  </svg>
                ) : null}
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Root>
