---
import FadeIn from "../components/fade-in";
import Navbar from "../components/navbar";
import Root from "../layouts/root.astro";

const whatsappUrl =
  "https://wa.me/50252810472?text=%C2%A1Hola!%20Estoy%20interesada(o)%20en%20agendar%20una%20evaluaci%C3%B3n%20metab%C3%B3lica%20y%20hormonal";

const socialLinks = [
  {
    href: "https://www.instagram.com/healthinstitute_int/",
    label: "Instagram",
  },
  {
    href: "https://www.facebook.com/HealthInstituteInt/",
    label: "Facebook",
  },
];
---

<Root
  title="Contacto | HI Institute"
  description="Escríbenos y agenda tu evaluación metabólica y hormonal en HI Institute."
>
  <Navbar client:load currentPath={Astro.url.pathname} />

  <main class="bg-neutral-100 pt-navbar">
    <section
      class="grid min-h-[calc(100svh-var(--spacing-navbar))] lg:grid-cols-2"
    >
      <div
        class="flex flex-col items-center justify-center bg-linear-to-br from-neutral-200/70 via-neutral-100 to-white px-4 py-16 text-center sm:px-6 lg:px-10"
      >
        <div class="mx-auto max-w-3xl">
          <FadeIn
            client:visible
            as="h1"
            className="text-(length:--step-4)/[1.02] font-[550] tracking-tighter text-balance text-neutral-800 md:text-(length:--step-5)/[0.98]"
          >
            Empecemos por entender qué necesita tu cuerpo.
          </FadeIn>
        </div>
      </div>

      <div
        class="bg-brand-blue relative flex flex-col justify-center px-4 py-20 text-white sm:px-6 lg:px-10"
      >
        <div class="mx-auto w-full max-w-xl">
          <FadeIn
            client:visible
            as="h2"
            className="max-w-xl text-(length:--step-4)/[1.02] font-[550] tracking-tighter text-balance md:text-(length:--step-5)/[0.98]"
          >
            Hablemos por WhatsApp.
          </FadeIn>
          <FadeIn
            client:visible
            as="p"
            delay={0.1}
            className="mt-6 max-w-lg text-base leading-relaxed text-white/85 md:text-(length:--step-0)/8"
          >
            Te responderemos para conocer tu caso y ayudarte a elegir el mejor
            punto de partida.
          </FadeIn>
          <FadeIn client:visible as="div" delay={0.2} className="mt-10">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noreferrer"
              class="group inline-flex items-center gap-4 rounded-full bg-white py-2 pr-2 pl-5 text-sm font-semibold text-neutral-800 transition-colors hover:bg-neutral-100"
            >
              <span>Escríbenos ahora</span>
              <span
                class="grid size-8 place-items-center rounded-full bg-neutral-800 text-white"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="size-4 transition-transform duration-300 group-hover:translate-x-0.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14"></path>
                  <path d="m13 6 6 6-6 6"></path>
                </svg>
              </span>
            </a>

            <div class="mt-6 flex items-center gap-4">
              {
                socialLinks.map((link) => (
                  <a
                    href={link.href}
                    aria-label={link.label}
                    target="_blank"
                    rel="noreferrer"
                    class="text-white transition-opacity hover:opacity-70"
                  >
                    {link.label === "Instagram" ? (
                      <svg
                        class="size-9"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.6"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <rect x="3" y="3" width="18" height="18" rx="5" />
                        <circle cx="12" cy="12" r="4" />
                        <circle
                          cx="17.5"
                          cy="6.5"
                          r="1"
                          fill="currentColor"
                          stroke="none"
                        />
                      </svg>
                    ) : (
                      <svg
                        class="size-9"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.49-3.91 3.78-3.91 1.1 0 2.24.2 2.24.2V8.6H15.2c-1.24 0-1.63.78-1.63 1.57v1.89h2.78l-.44 2.91h-2.34V22C18.34 21.24 22 17.08 22 12.06Z" />
                      </svg>
                    )}
                  </a>
                ))
              }
              <a
                href="tel:+50252810472"
                class="text-sm font-medium text-white/80 underline decoration-white/30 underline-offset-4 transition-colors hover:text-white"
              >
                +502 5281 0472
              </a>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>
  </main>
</Root>
