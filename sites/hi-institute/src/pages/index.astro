---
import hero1 from "../assets/hero/1.webp";
import hero2 from "../assets/hero/2.webp";
import hero3 from "../assets/hero/3.webp";
import Footer from "../components/footer.astro";
import Hero from "../components/hero";
import Navbar from "../components/navbar";
import Root from "../layouts/root.astro";

const heroImages = [
  { src: hero3.src, alt: "HI Institute clinical space" },
  { src: hero1.src, alt: "HI Institute treatment room" },
  { src: hero2.src, alt: "HI Institute care experience" },
];
---

<Root
  title="HI Institute"
  description="HI Institute is preparing a new, accurate website experience."
>
  <Navbar client:load currentPath={Astro.url.pathname} />
  <Hero
    client:load
    title="Expertos en metabolismo y equilibrio hormonal"
    align="left"
    images={heroImages}
    actions={[{ href: "/contacto", label: "AGENDA TU CITA AHORA" }]}
  />
  <Footer />
</Root>
