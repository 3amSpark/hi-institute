---
import FadeIn from "./fade-in";
import FounderGradientBand from "./founder-gradient-band";
---

<section class="bg-white pt-25">
  <div class="max-w-desktop relative mx-auto">
    <div
      class="relative flex min-h-52 items-center justify-center px-4 py-12 sm:min-h-56 lg:hidden"
    >
      <FounderGradientBand client:visible />

      <FadeIn
        client:visible
        as="h2"
        className="relative z-10 text-center text-(length:--step-5)/12 font-bold tracking-[0.125em] text-balance text-white uppercase"
      >
        Feel Better Than Ever
      </FadeIn>
    </div>

    <FadeIn
      client:visible
      disableBlur
      className="relative z-10 -mt-8 flex w-full items-center justify-center px-4 lg:mt-8 lg:hidden"
    >
      <img
        src="/assets/herbert.webp"
        alt="Dr. Herbert Maradiaga"
        class="aspect-4/3 h-auto w-full max-w-sm border-6 border-white object-cover object-center sm:max-w-md"
        loading="lazy"
      />
    </FadeIn>

    <div class="relative hidden lg:block">
      <FounderGradientBand client:visible />

      <div class="relative grid items-center gap-3 lg:grid-cols-[1fr_1fr_1fr]">
        <div class="relative z-10 py-12 lg:py-18">
          <FadeIn
            client:visible
            as="h2"
            className="text-center text-(length:--step-5)/20 font-bold tracking-[0.125em] text-white uppercase"
          >
            Feel Better
          </FadeIn>
        </div>
        <FadeIn
          client:visible
          disableBlur
          className="relative z-10 col-start-2 flex w-full items-center justify-center"
        >
          <img
            src="/assets/herbert.webp"
            alt="Dr. Herbert Maradiaga"
            class="aspect-4/3 h-96 border-6 border-white object-cover object-center"
            loading="lazy"
          />
        </FadeIn>

        <div class="relative z-10 py-12 lg:py-18">
          <FadeIn
            client:visible
            as="h2"
            className="text-center text-(length:--step-5)/20 font-bold tracking-[0.125em] text-white uppercase"
          >
            THAN EVER
          </FadeIn>
        </div>
      </div>
    </div>
  </div>

  <div
    class="mx-auto mt-10 grid max-w-5xl justify-center gap-8 px-4 pt-10 text-(length:--step-0)/8 text-neutral-900 lg:mt-6 lg:grid-cols-1 lg:gap-8 lg:px-24"
  >
    <FadeIn client:visible as="p" delay={0.125}>
      <span
        class="from-brand-blue to-brand-green bg-linear-to-br bg-clip-text font-semibold text-transparent"
        >Desde 2010
      </span> somos expertos en metabolismo, equilibrio hormonal y bienestar integral.
      Hemos construido clínicas especializadas donde la experiencia médica y la tecnología
      avanzada trabajan para una sola meta:
      <span
        class="mt-8 block text-(length:--step-0)/8 font-semibold text-neutral-950"
      >
        Que te sientas mejor que nunca.
      </span>
    </FadeIn>

    <FadeIn client:visible as="p" delay={0.2}>
      Por eso nuestro lema es Feel Better Than Ever. <br />No es solo un slogan.
      <br />
      Es una promesa.
    </FadeIn>

    <FadeIn
      client:visible
      className="place-self-end pr-2"
      delay={0.22}
      amount={0.5}
    >
      <img
        src="https://onlinepngtools.com/images/examples-onlinepngtools/george-walker-bush-signature.png"
        alt=""
        class="h-16 scale-120"
      />
    </FadeIn>
  </div>
</section>
