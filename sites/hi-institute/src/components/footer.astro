---
import FadeIn from "./fade-in";

const navLinks = [
  { href: "/", label: "Inicio" },
  { label: "Tratamientos" },
  { href: "/farmacia", label: "Farmacia" },
  { label: "Clínicas" },
  { href: "/contacto", label: "Contacto" },
];

const mapsUrl =
  "https://www.google.com/maps/search/?api=1&query=The%20Health%20Institute%20Centro%20de%20Fertilidad%20y%20Peso%20en%20Guatemala%2C%20Avenida%20La%20Reforma%209-55%2C%20Cdad.%20de%20Guatemala%2001010";
const mapsEmbedUrl =
  "https://www.google.com/maps?q=The%20Health%20Institute%20Centro%20de%20Fertilidad%20y%20Peso%20en%20Guatemala%2C%20Avenida%20La%20Reforma%209-55%2C%20Cdad.%20de%20Guatemala%2001010&z=16&output=embed";
const currentYear = new Date().getFullYear();
---

<footer class="overflow-hidden">
  <section
    class="bg-brand-blue flex min-h-96 flex-col items-center justify-center border-t border-neutral-200 text-center"
  >
    <FadeIn
      client:visible
      as="h2"
      className="leading-tighter text-(length:--step-2) font-medium tracking-tight text-white"
    >
      Tu cuerpo te está hablando.<br />
      <span class="text-(length:--step-4)/8 tracking-tighter">
        Es momento de escucharlo.
      </span>
    </FadeIn>
    <a
      href="/contacto"
      class="mt-8 w-fit rounded-full bg-white px-6 py-1.5 text-base font-medium transition-opacity"
    >
      ¡Agenda tu cita hoy!
    </a>
  </section>

  <section
    class="bg-brand-green flex max-h-svh flex-col items-center justify-between text-center text-white md:flex-row"
  >
    <FadeIn
      client:visible
      as="h2"
      className="flex-1 py-20 text-(length:--step-4) leading-tight font-medium tracking-tighter text-balance"
    >
      Estamos más cerca<br />
      de lo que crees.
    </FadeIn>

    <iframe
      src={mapsEmbedUrl}
      title="HI Institute en Avenida La Reforma 9-55, Ciudad de Guatemala"
      class="h-160 w-full shrink-0 md:flex-2"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"></iframe>
  </section>

  <section class="bg-neutral-700 py-14 md:py-18">
    <div
      class="mx-auto grid max-w-7xl gap-16 md:grid-cols-2 lg:grid-cols-[auto_1fr_1fr] lg:items-start"
    >
      <div>
        <a href="/" aria-label="HI Institute International home">
          <img
            src="/Asset%201.svg"
            alt="HI Health Institute International"
            class="h-auto w-54 max-w-full pl-4"
            loading="lazy"
          />
        </a>
      </div>

      <nav
        aria-label="Footer navigation"
        class="grid gap-x-4 gap-y-6 pl-4 sm:grid-cols-2 md:pl-0"
      >
        {
          navLinks.map((link) =>
            link.href ? (
              <a
                href={link.href}
                class="text-(length:--step--1) font-medium text-white transition-opacity hover:opacity-75"
              >
                {link.label}
              </a>
            ) : (
              <span class="text-(length:--step--1) font-medium text-white/80">
                {link.label}
              </span>
            ),
          )
        }
      </nav>

      <div class="pl-4 md:col-span-2 lg:col-span-1">
        <h2 class="text-(length:--step-0)/8 font-medium text-white">
          Recibe noticias de HI Institute
        </h2>
        <p class="text-(length:--step--1)/6 font-medium text-white/90">
          Sé la primera persona en conocer nuevos tratamientos, suplementos y
          más.
        </p>
        <form
          class="mt-6 flex w-64 items-center gap-2 rounded-full bg-white p-1.5"
          action="#"
        >
          <label class="sr-only" for="footer-email">Email</label>
          <input
            id="footer-email"
            type="email"
            name="email"
            placeholder="Tu correo"
            class="min-w-0 flex-1 bg-transparent px-2 py-1.5 text-sm text-neutral-800 outline-none placeholder:text-sm placeholder:text-neutral-400"
          />

          <span
            class="bg-brand-blue grid size-8 place-items-center rounded-full text-white"
          >
            <svg
              class="size-4.5 transition-transform duration-300 ease-out group-hover:-rotate-45"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14"></path>
              <path d="m13 6 6 6-6 6"></path>
            </svg>
          </span>
        </form>
      </div>
    </div>
    <p
      class="mx-auto mt-10 text-center text-(length:--step--1)/7 font-medium text-white/90 md:mt-16"
    >
      HI Institute forma parte de A Tu Origen, Sociedad Anónima. © {
        currentYear
      }. Todos los derechos reservados
    </p>
  </section>
</footer>
