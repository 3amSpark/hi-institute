---
import FadeIn from "./fade-in";

const signals = [
  {
    text: 'Te cuesta bajar de peso aunque "comes bien".',
    label: "Metabólico",
  },
  {
    text: "Te sientes cansada(o) sin razón alguna.",
    label: "Energía",
  },
  {
    text: "Tu ciclo es irregular o doloroso.",
    label: "Hormonal",
  },
  {
    text: "Te ha costado embarazarte.",
    label: "Fertilidad",
  },
  {
    text: "Tienes ansiedad por azúcar o carbohidratos.",
    label: "Metabólico",
  },
  {
    text: "Sientes que tu cuerpo cambió, y no sabes por qué.",
    label: "Sistémico",
  },
];
---

<section class="relative overflow-hidden bg-neutral-50 px-4 py-12 lg:py-2">
  <div
    class="max-w-desktop mx-auto grid gap-0 lg:grid-cols-[1.3fr_1fr] lg:gap-10"
  >
    <div class="max-w-3xl lg:row-start-1">
      <FadeIn
        client:visible
        as="div"
        className="flex h-full flex-col justify-center"
      >
        <h2
          class="text-(length:--step-5)/12 font-semibold tracking-tighter text-balance text-neutral-600 md:text-(length:--step-5)/16"
        >
          Tal vez te está <span class="text-brand-green"> pasando esto.</span>
        </h2>
      </FadeIn>
    </div>

    <FadeIn client:visible as="div" delay={0.1} className="lg:row-span-2">
      <ol
        class="mt-8 divide-y divide-neutral-200 border-t border-neutral-200 last:pb-0 lg:mt-0 lg:border-0"
      >
        {
          signals.map((signal) => (
            <li class="py-7.5">
              <span class="text-(length:--step--2)/2 font-bold tracking-[0.2em] text-neutral-400 uppercase">
                {signal.label}
              </span>
              <p class="mt-2 max-w-3xl text-(length:--step-2)/10 font-semibold tracking-tight text-balance text-neutral-600">
                {signal.text}
              </p>
            </li>
          ))
        }
      </ol>
    </FadeIn>

    <div class="lg:row-start-2 lg:max-w-3xl">
      <FadeIn
        client:visible
        as="div"
        className="flex h-full flex-col justify-center"
      >
        <p class="text-(length:--step-0)/8 text-neutral-600">
          Seis señales que escuchamos cada semana en consulta.<br />No son tu
          personalidad.<br />Son señales de que tu cuerpo necesita una
          evaluación más completa.
        </p>
      </FadeIn>
    </div>
  </div>
</section>

<section class="bg-brand-blue relative overflow-hidden px-4 py-28 lg:py-40">
  <div class="max-w-desktop mx-auto">
    <FadeIn
      client:visible
      as="div"
      className="flex flex-col items-start gap-12 md:flex-row md:items-end md:justify-between md:gap-16"
    >
      <p
        class="text-(length:--step-4)/[1.05] font-[550] tracking-tight text-balance text-white md:text-(length:--step-5)/[1.05]"
      >
        No es normal.<br /><span class="text-white/70"
          >Y no tienes que vivir así.</span
        >
      </p>

      <a
        href="/contacto"
        class="group inline-flex w-fit shrink-0 items-center gap-3 rounded-full bg-white py-2 pr-2 pl-6 text-(length:--step-0) font-medium text-neutral-900 transition-colors duration-300 hover:bg-neutral-100"
      >
        <span>Conocer más</span>
        <svg
          class="bg-brand-blue size-7 shrink-0 rounded-full p-1.5 text-white transition-transform duration-300 ease-out group-hover:rotate-45"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M7 17 17 7"></path>
          <path d="M8 7h9v9"></path>
        </svg>
      </a>
    </FadeIn>
  </div>
</section>
