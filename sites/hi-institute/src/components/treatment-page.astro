---
import FadeIn from "./fade-in";

interface Props {
  heroImage: string;
  heroImageAlt: string;
  heroTitle: string;
  heroDescription: string;
  treatmentName: string;
}

const { heroImage, heroImageAlt, heroTitle, heroDescription, treatmentName } =
  Astro.props;
---

<main>
  <section
    class="mt-navbar relative min-h-[50svh] overflow-hidden bg-neutral-900 text-white"
  >
    <img
      src={heroImage}
      alt={heroImageAlt}
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-black/25" aria-hidden="true"></div>

    <div
      class="relative z-10 mx-auto flex min-h-[50svh] max-w-7xl items-center justify-center px-6 py-20 text-center lg:px-10"
    >
      <div class="max-w-4xl">
        <FadeIn
          client:visible
          as="h1"
          className="text-(length:--step-5)/13 font-[550] tracking-tighter text-white"
        >
          {heroTitle}
        </FadeIn>
        <FadeIn
          client:visible
          as="p"
          className="mx-auto mt-4 max-w-3xl text-(length:--step-0)/8 text-white"
          delay={0.1}
        >
          {heroDescription}
        </FadeIn>
      </div>
    </div>
  </section>

  <section class="mb-16 bg-gray-100 px-6 py-20 md:py-28 lg:px-10">
    <div
      class="max-w-desktop mx-auto grid w-full grid-cols-1 items-center justify-around gap-4 gap-20 md:grid-cols-2"
    >
      <FadeIn
        client:visible
        as="h2"
        className="text-(length:--step-4) leading-tight font-semibold tracking-tighter md:text-center"
      >
        {treatmentName}
      </FadeIn>

      <FadeIn
        client:visible
        as="div"
        className="text-ne max-w-[80ch] space-y-8 text-left text-(length:--step-0)/8 text-balance"
        delay={0.1}
      >
        <slot />
      </FadeIn>
    </div>
  </section>

  <slot name="sections" />
</main>
