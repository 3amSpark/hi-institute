---
import FadeIn from "../fade-in";
import FounderImageReveal from "./founder-image-reveal";
import ScrollRevealHeading from "./scroll-reveal-heading";
---

<section class="relative overflow-hidden">
  <FounderImageReveal client:load />

  <div class="bg-brand-blue relative z-10 grid min-h-96 items-center">
    <div
      class="grid h-full w-full max-w-5xl items-center place-self-center text-center text-(length:--step-5)/14 font-medium tracking-tighter text-balance text-white"
    >
      <ScrollRevealHeading
        client:visible
        text="Entendemos tu cuerpo antes de intentar cambiarlo."
      />
    </div>
  </div>
  <div
    class="relative z-10 flex w-full flex-col-reverse items-start justify-between gap-8 pb-8 text-(length:--step-0)/8 text-pretty lg:flex-row lg:items-center lg:pb-0"
  >
    <FadeIn
      client:visible
      as="p"
      className="max-w-prose min-w-0 px-4 lg:basis-1/2 lg:pl-10"
      delay={0.2}
    >
      <span class="font-semibold">Desde 2010</span> somos expertos en metabolismo,
      equilibrio hormonal y bienestar integral. Hemos construido clínicas especializadas
      donde la experiencia médica y la tecnología avanzada trabajan para una sola
      meta:
      <span class="my-4 block font-semibold">
        Que te sientas mejor que nunca.
      </span>

      Por eso nuestro lema es
      <span class="font-semibold"> Feel Better Than Ever. </span>

      No es solo un slogan. Es una promesa. Significa ir más allá de tratar
      síntomas. Significa ayudarte a recuperar energía, control, confianza y
      calidad de vida.

      <img
        src="/assets/images/home/founder/signature.webp"
        alt=""
        class="mt-10 h-20 contrast-150"
      />
    </FadeIn>

    <img
      src="/assets/images/home/founder/dr-herbert-miranda.jpg"
      alt="Dr. Herbert Miranda"
      class="relative z-10 aspect-4/3 w-full min-w-0 object-cover lg:basis-1/2"
      loading="lazy"
    />
  </div>
</section>
