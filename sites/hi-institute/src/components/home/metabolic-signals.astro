---
import FadeIn from "../fade-in";
import SignalScroller from "./signal-scroller";

const signals = [
  {
    text: 'Te cuesta bajar de peso aunque "comes bien".',
    description:
      "Puede haber señales metabólicas u hormonales que no se resuelven solo con dieta.",
    image: "/assets/images/home/signals/weight.png",
    href: "/tratamientos/metabolismo-peso",
  },
  {
    text: "Te sientes cansada(o) sin razón alguna.",
    description:
      "La energía baja constante puede ser una pista de desbalance interno.",
    image: "/assets/images/home/signals/fatigue.png",
    href: "/tratamientos/balance-hormonal",
  },
  {
    text: "Tu ciclo es irregular o doloroso.",
    description:
      "Tu ciclo también habla de inflamación, estrés y salud hormonal.",
    image: "/assets/images/home/signals/menstrual-cycle.png",
    href: "/tratamientos/salud-femenina-ginecologica",
  },
  {
    text: "Te ha costado embarazarte.",
    description:
      "Entender tus hormonas y metabolismo puede abrir nuevas respuestas.",
    image: "/assets/images/home/signals/fertility.png",
    href: "/tratamientos/fertilidad-reproduccion",
  },
  {
    text: "Tienes ansiedad por azúcar o carbohidratos.",
    description:
      "No siempre es falta de voluntad; puede estar relacionado con glucosa e insulina.",
    image: "/assets/images/home/signals/sugar-cravings.png",
    href: "/tratamientos/diabetes",
  },
  {
    text: "Sientes que tu cuerpo cambió, y no sabes por qué.",
    description:
      "Cuando algo se siente distinto, vale la pena investigarlo con datos claros.",
    image: "/assets/images/home/signals/fertility.png",
    href: "/tratamientos/balance-hormonal",
  },
];
---

<section class="mx-auto bg-gray-100">
  <FadeIn
    client:visible
    as="div"
    className="mx-auto flex flex-col gap-4 px-4 pt-10 pb-6 sm:px-6 md:flex-row md:items-end md:justify-between md:gap-8 md:px-10 md:py-20"
  >
    <h2 class="text-(length:--step-4)/[1.05] font-medium tracking-tighter">
      Te ha pasado alguna vez:
    </h2>
    <p
      class="max-w-md text-(length:--step-0)/7 font-medium tracking-tight text-neutral-500"
    >
      Si reconoces alguno, no lo dejes pasar. <br />
      <span class="font-semibold"> Tiene explicación, y solución. </span>
    </p>
  </FadeIn>

  <SignalScroller client:visible signals={signals} />
</section>
