---
import FadeIn from "../fade-in";

const programs = [
  {
    title: "Metabolismo y control de peso",
    description:
      "Evaluamos glucosa, insulina, hormonas y composición corporal para ayudarte a bajar de peso, recuperar energía y sostener resultados.",
    image: "/assets/images/treatments/metabolism/banner.jpg",
    href: "/tratamientos/metabolismo-peso",
  },
  {
    title: "Balance hormonal y energía",
    description:
      "Identificamos y tratamos desbalances que pueden estar detrás del cansancio, los cambios de peso y otros síntomas persistentes.",
    image: "/assets/images/treatments/hormonal-balance/banner.jpg",
    href: "/tratamientos/balance-hormonal",
  },
  {
    title: "Fertilidad y reproducción",
    description:
      "Estudiamos los factores hormonales y metabólicos que pueden estar dificultando el embarazo y definimos el siguiente paso.",
    image: "/assets/images/treatments/fertility/banner.webp",
    href: "/tratamientos/fertilidad-reproduccion",
  },
  {
    title: "Salud femenina y ginecológica",
    description:
      "Atendemos ciclos irregulares, dolor, cambios hormonales y salud ginecológica con una evaluación integral.",
    image: "/assets/images/treatments/womens-health/banner.jpg",
    href: "/tratamientos/salud-femenina-ginecologica",
  },
];
---

<section class="bg-gray-50 pb-32">
  <FadeIn
    client:visible
    as="div"
    className="flex w-full flex-col items-start justify-between gap-2 bg-gray-50 px-4 pt-20 pb-10 lg:flex-row lg:items-center lg:gap-0 lg:px-10"
  >
    <h2
      class="text-(length:--step-5) leading-tight font-medium tracking-tighter text-balance"
    >
      Nuestros tratamientos
    </h2>
    <p
      class="max-w-prose text-(length:--step-0)/7 text-pretty text-neutral-800"
    >
      Evaluamos la causa de tus síntomas y diseñamos un tratamiento médico según
      lo que tu cuerpo necesita.
    </p>
  </FadeIn>

  <div
    class="signal-scroller flex gap-4 overflow-x-auto overflow-y-hidden px-4 pb-3 md:mt-16 lg:grid lg:grid-cols-2 lg:gap-6 lg:overflow-visible lg:px-10 lg:pb-0 xl:grid-cols-4"
  >
    {
      programs.map((program, index) => (
        <FadeIn
          client:visible
          as="div"
          delay={index * 0.1}
          className="w-[82vw] max-w-sm shrink-0 md:w-auto md:max-w-none"
        >
          <a
            href={program.href}
            class="group flex h-full flex-col text-neutral-900 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-neutral-900"
          >
            <div class="relative flex aspect-4/5 overflow-hidden bg-neutral-900 text-white">
              <img
                src={program.image}
                alt=""
                class="r absolute inset-0 h-full w-full object-cover saturate-75 transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-105 group-focus-visible:scale-[101%]"
                loading="lazy"
                decoding="async"
              />
              <span
                class="program-card-gradient absolute inset-0"
                aria-hidden="true"
              />

              <div class="relative z-10 mt-auto p-4 lg:p-5">
                <h3 class="text-(length:--step-2) leading-tight font-medium tracking-tighter text-pretty">
                  {program.title}
                </h3>
              </div>
            </div>

            <p class="mt-5 max-w-[38ch] text-base leading-relaxed text-pretty text-neutral-600 transition-colors duration-300 group-hover:text-neutral-900 group-focus-visible:text-neutral-900">
              {program.description}
            </p>
            <span class="mt-5 inline-flex w-fit items-center gap-2 border-b-2 border-neutral-300 pb-1 text-sm font-semibold transition-colors group-hover:border-neutral-400 group-focus-visible:border-neutral-400">
              Conoce el tratamiento
              <svg
                viewBox="0 0 24 24"
                class="size-4 text-neutral-300 transition-transform duration-300 group-hover:translate-x-1 group-hover:text-neutral-900 group-focus-visible:translate-x-1"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M5 12h14" />
                <path d="m13 6 6 6-6 6" />
              </svg>
            </span>
          </a>
        </FadeIn>
      ))
    }
  </div>
</section>
