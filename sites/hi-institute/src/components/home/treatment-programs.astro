---
import FadeIn from "../fade-in";

const programs = [
  {
    title: "Metabolismo y control de peso",
    description:
      "Evaluamos glucosa, insulina, hormonas y composición corporal para ayudarte a bajar de peso, recuperar energía y sostener resultados.",
    image: "/assets/images/home/steps/progress.jpg",
    href: "/tratamientos/metabolismo-peso",
  },
  {
    title: "Balance hormonal y energía",
    description:
      "Identificamos y tratamos desbalances que pueden estar detrás del cansancio, los cambios de peso y otros síntomas persistentes.",
    image: "/assets/images/treatments/hormonal-balance/banner.jpg",
    href: "/tratamientos/balance-hormonal",
  },
  {
    title: "Fertilidad y reproducción",
    description:
      "Estudiamos los factores hormonales y metabólicos que pueden estar dificultando el embarazo y definimos el siguiente paso.",
    image: "/assets/images/treatments/fertility/banner.webp",
    href: "/tratamientos/fertilidad-reproduccion",
  },
  {
    title: "Salud femenina y ginecológica",
    description:
      "Atendemos ciclos irregulares, dolor, cambios hormonales y salud ginecológica con una evaluación integral.",
    image: "/assets/images/treatments/womens-health/banner.jpg",
    href: "/tratamientos/salud-femenina-ginecologica",
  },
];
---

<section class="bg-gray-50/70 pb-32">
  <FadeIn
    client:visible
    as="div"
    className="flex w-full flex-col items-start justify-between gap-2 bg-gray-50 px-4 pt-20 pb-10 lg:flex-row lg:items-center lg:gap-0 lg:px-10"
  >
    <h3 class="text-h3 leading-tight font-[450] tracking-tighter text-balance">
      Nuestros tratamientos
    </h3>
    <p class="text-p max-w-prose text-pretty text-neutral-800">
      Evaluamos la causa de tus síntomas y diseñamos un tratamiento médico según
      lo que tu cuerpo necesita.
    </p>
  </FadeIn>

  <div class="relative">
    <FadeIn client:visible as="div">
      <div
        id="treatment-programs-scroller"
        class="signal-scroller flex snap-x snap-mandatory gap-4 overflow-x-auto overflow-y-hidden scroll-smooth px-4 pb-3 md:mt-16 lg:grid lg:snap-none lg:grid-cols-2 lg:gap-6 lg:overflow-visible lg:px-10 lg:pb-0 xl:grid-cols-4"
      >
        {
          programs.map((program) => (
            <div
              data-treatment-card
              class="w-[82vw] max-w-sm shrink-0 snap-start scroll-ml-4 md:w-auto md:max-w-none lg:scroll-ml-0"
            >
              <a
                href={program.href}
                class="group flex h-full flex-col text-neutral-900 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-neutral-900"
              >
                <div class="item relative flex aspect-4/5 overflow-hidden bg-neutral-900 text-white">
                  <img
                    src={program.image}
                    alt=""
                    class="r absolute inset-0 h-full w-full object-cover saturate-75 transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-105 group-focus-visible:scale-[101%]"
                    loading="lazy"
                    decoding="async"
                  />
                  <span
                    class="program-card-gradient absolute inset-0"
                    aria-hidden="true"
                  />

                  <div class="relative z-10 mt-auto pb-4 pl-4">
                    <h4 class="text-h4 font-medium text-balance">
                      {program.title}
                    </h4>
                  </div>
                </div>

                <p class="text-p mt-5 max-w-[38ch] text-pretty text-neutral-700 transition-colors duration-300 group-hover:text-neutral-900 group-focus-visible:text-neutral-900">
                  {program.description}
                </p>
                <span class="text-p group-hover:text-brand-dark-blue mt-5 inline-flex w-fit items-center gap-2 pb-1 font-semibold transition-colors">
                  Conoce el tratamiento
                  <svg
                    viewBox="0 0 24 24"
                    class="group-hover:text-brand-dark-blue size-4 transition-transform duration-300 group-hover:translate-x-1 group-focus-visible:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14" />
                    <path d="m13 6 6 6-6 6" />
                  </svg>
                </span>
              </a>
            </div>
          ))
        }
      </div>
    </FadeIn>

    <button
      id="treatment-programs-next"
      type="button"
      class="absolute top-[40%] right-4 z-20 grid size-11 -translate-y-1/2 place-items-center rounded-full bg-white/95 text-neutral-900 shadow-sm/10 backdrop-blur-sm transition-[opacity,transform,background-color] duration-300 hover:scale-105 hover:bg-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-800 lg:hidden"
      aria-label="Ver más tratamientos"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-5"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M5 12h14"></path>
        <path d="m13 6 6 6-6 6"></path>
      </svg>
    </button>
  </div>
</section>

<script>
  const scroller = document.getElementById("treatment-programs-scroller");
  const nextButton = document.getElementById("treatment-programs-next");

  const updateScrollCue = () => {
    if (!scroller || !nextButton) return;

    const hasMore =
      scroller.scrollLeft < scroller.scrollWidth - scroller.clientWidth - 2;
    nextButton.toggleAttribute("hidden", !hasMore);
  };

  nextButton?.addEventListener("click", () => {
    const firstCard = scroller?.querySelector("[data-treatment-card]");
    if (!scroller || !(firstCard instanceof HTMLElement)) return;

    const gap = Number.parseFloat(getComputedStyle(scroller).columnGap) || 0;
    scroller.scrollBy({
      left: firstCard.getBoundingClientRect().width + gap,
      behavior: "smooth",
    });
  });

  scroller?.addEventListener("scroll", updateScrollCue, { passive: true });
  window.addEventListener("resize", updateScrollCue);
  updateScrollCue();
</script>
