---
import FadeIn from "./fade-in";

interface Props {
  title: string;
  image?: string;
  imageAlt?: string;
  reverse?: boolean;
  placeholderLabel?: string;
}

const {
  title,
  image,
  imageAlt = "",
  reverse = false,
  placeholderLabel,
} = Astro.props;
---

<section class="bg-white px-6 pb-16 lg:px-10">
  <div
    class:list={[
      "max-w-desktop mx-auto flex flex-col gap-12 md:items-start md:gap-20",
      reverse ? "md:flex-row-reverse" : "md:flex-row",
    ]}
  >
    <FadeIn
      client:visible
      className="from-brand-green relative w-full bg-linear-to-r via-[#b7d4d7] to-[#cfd0dc] p-1.5 md:w-1/2"
    >
      {
        image ? (
          <img
            src={image}
            alt={imageAlt}
            loading="lazy"
            decoding="async"
            class="relative aspect-5/3 w-full object-cover"
          />
        ) : (
          <div class="relative flex aspect-[4/3] w-full items-center justify-center bg-neutral-100 p-10 text-center">
            <span class="text-brand-blue text-(length:--step-1) font-semibold tracking-[0.12em]">
              {placeholderLabel}
            </span>
          </div>
        )
      }
    </FadeIn>

    <div class="w-full md:w-1/2">
      <FadeIn
        client:visible
        as="h2"
        className="text-brand-green text-h3 max-w-xl leading-tight font-[450] tracking-tighter text-pretty"
      >
        {title}
      </FadeIn>
      <FadeIn
        client:visible
        as="div"
        className="text-p mt-8 space-y-6 text-balance text-neutral-700"
        delay={0.1}
      >
        <slot />
      </FadeIn>
    </div>
  </div>
</section>
