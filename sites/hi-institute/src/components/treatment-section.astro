---
import FadeIn from "./fade-in";

interface Props {
  title: string;
  image?: string;
  imageAlt?: string;
  reverse?: boolean;
  placeholderLabel?: string;
}

const {
  title,
  image,
  imageAlt = "",
  reverse = false,
  placeholderLabel,
} = Astro.props;
---

<section class="bg-white px-6 py-16 md:py-20 lg:px-10">
  <div
    class:list={[
      "mx-auto flex max-w-6xl flex-col gap-12 md:items-center md:gap-20",
      reverse ? "md:flex-row-reverse" : "md:flex-row",
    ]}
  >
    <FadeIn client:visible className="relative w-full md:w-1/2">
      <div
        class="from-brand-green absolute top-10 -right-5 -bottom-7 left-8 bg-linear-to-r via-[#b7d4d7] to-[#cfd0dc] md:-right-8 md:left-12"
        aria-hidden="true"
      >
      </div>
      {
        image ? (
          <img
            src={image}
            alt={imageAlt}
            loading="lazy"
            decoding="async"
            class="relative aspect-[4/3] w-full object-cover"
          />
        ) : (
          <div class="relative flex aspect-[4/3] w-full items-center justify-center bg-neutral-100 p-10 text-center">
            <span class="text-brand-blue text-(length:--step-1) font-semibold tracking-[0.12em]">
              {placeholderLabel}
            </span>
          </div>
        )
      }
    </FadeIn>

    <div class="w-full md:w-1/2">
      <FadeIn
        client:visible
        as="h2"
        className="text-brand-blue max-w-xl text-(length:--step-3)/10 font-semibold"
      >
        {title}
      </FadeIn>
      <FadeIn
        client:visible
        as="div"
        className="mt-8 space-y-6 text-(length:--step-0)/8 text-neutral-600"
        delay={0.1}
      >
        <slot />
      </FadeIn>
    </div>
  </div>
</section>
