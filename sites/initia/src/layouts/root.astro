---
import "../styles/fonts.css";
import "../styles/global.css";
import ChatFab from "../components/chat-fab.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = "initia - Centro de Fertilidad",
  description = "Centro de fertilidad especializado en tratamientos de reproducción asistida, FIV, inseminación artificial y acompañamiento integral para formar tu familia.",
  image = "/hero.webp",
  type = "website",
} = Astro.props;

const siteName = "initia";
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;
const imageURL = Astro.site ? new URL(image, Astro.site).href : image;
const gaMeasurementId = "G-KWYF3D6T5G";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <script
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
    ></script>
    <script define:vars={{ gaMeasurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }

      function getPageRoute() {
        return window.location.pathname;
      }

      function trackEvent(eventName, params) {
        if (typeof gtag !== "function") return;
        gtag("event", eventName, params);
      }

      function trackPageVisit() {
        const pageRoute = getPageRoute();

        trackEvent("visit_page", {
          page_route: pageRoute,
        });

        window.setTimeout(() => {
          trackEvent("engaged_visit", {
            page_route: pageRoute,
            engaged_seconds: 30,
          });
        }, 30000);
      }

      gtag("js", new Date());
      gtag("config", gaMeasurementId);

      trackPageVisit();

      document.addEventListener("click", (event) => {
        const cta = event.target.closest("[data-ga-lead-cta]");
        if (!cta) return;

        trackEvent("generate_lead", {
          method: "whatsapp",
          cta_location: cta.dataset.gaLeadCta,
          page_route: getPageRoute(),
        });
      });
    </script>
  </head>
  <body class="selection:bg-initia/30 relative bg-white">
    <ChatFab />
    <slot />
  </body>
</html>
